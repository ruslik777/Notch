  { id:'flame',    svg:`<svg viewBox="0 0 40 40"><path d="M20 4c0 0-10 9-10 18a10 10 0 0020 0c0-4-2-7-2-7s0 5-4 6c1-6-4-10-4-17z" fill="currentColor"/></svg>` },
