const SUPABASE_URL      = 'https://uwrzviupkbzaurlmevwk.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InV3cnp2aXVwa2J6YXVybG1ldndrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcwNDY1MDcsImV4cCI6MjA5MjYyMjUwN30.YMBK4AdKor8RuGYlkr-5Aaq6OWw5QzX18gqoZpc39zE';
